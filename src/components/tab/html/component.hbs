{{#with component.data}}
  <section
    id="{{#if metadata.id_field.value}}{{ metadata.id_field.value }}{{else}}tag-{{ assetid }}{{/if}}"
    class="
      qld__body
      {{#if metadata.theme.value}}
        qld__body--{{ metadata.theme.value }}
      {{/if}}
      {{#ifCond metadata.display.value '==' 'full'}}
        qld__body--full-width
        qld__tab-section
      {{/ifCond}}
    "
  >
    <div class="container-fluid">

      {{#if metadata.intro_heading.value}}
        <div class="row">

          <div class="qld__tab-intro col-xs-12 {{ metadata.intro_width.value }}"
          >

            {{#ifCond metadata.intro_heading_level.value '==' 'h5'}}
              <h5>
                {{ metadata.intro_heading.value }}
              </h5>
            {{else ifCond metadata.intro_heading_level.value '==' 'h4'}}
              <h4>{{ metadata.intro_heading.value }}</h4>
            {{else ifCond metadata.intro_heading_level.value '==' 'h3'}}
              <h3>{{ metadata.intro_heading.value }}</h3>
            {{else}}
              <h2>
                {{ metadata.intro_heading.value }}
              </h2>
            {{/ifCond}}

            {{#if metadata.intro_body.value}}
              {{{ metadata.intro_body.value }}}
            {{/if}}

          </div>
        </div>
      {{else}}
        {{#if metadata.intro_body.value}}
          <div class="row">

            <div
              class="qld__tab-intro col-xs-12 {{ metadata.intro_width.value }}"
            >

              {{#if metadata.intro_heading.value}}
                {{#ifCond metadata.intro_heading_level.value '==' 'h5'}}
                  <h5>
                    {{ metadata.intro_heading.value }}
                  </h5>
                {{else ifCond metadata.intro_heading_level.value '==' 'h4'}}
                  <h4>{{ metadata.intro_heading.value }}</h4>
                {{else ifCond metadata.intro_heading_level.value '==' 'h3'}}
                  <h3>{{ metadata.intro_heading.value }}</h3>
                {{else}}
                  <h2>
                    {{ metadata.intro_heading.value }}
                  </h2>
                {{/ifCond}}
              {{/if}}

              {{{ metadata.intro_body.value }}}

            </div>
          </div>
        {{/if}}
      {{/if}}

      <div
        id="tab-{{ assetid }}"
        class="
          qld__tab-container
          {{#if metadata.theme.value}}
            qld__tab-container--{{ metadata.theme.value }}
          {{/if}}
          qld__tab-container__fixed
        "
      >
        <button
          class="qld__tab-nav__item-scroll tab-overflow-nav-button-left"
          aria-hidden="true"
          aria-label="Scroll tab buttons left"
          tabindex="-1"
        >
          <svg
            class="qld__icon qld__icon--sm"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
          >
            <use
              href="{{ @root.site.metadata.coreSiteIcons.value }}#chevron-left"
            ></use>
          </svg>
        </button>
        <button
          class="qld__tab-nav__item-scroll tab-overflow-nav-button-right"
          aria-hidden="true"
          aria-label="Scroll tab buttons right"
          tabindex="-1"
        >
          <svg
            class="qld__icon qld__icon--sm"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
          >
            <use
              href="{{ @root.site.metadata.coreSiteIcons.value }}#chevron-right"
            ></use>
          </svg>
        </button>
        <div class="qld__tabs" role="tablist">
          {{#ifCond metadata.type.value '==' 'wysiwyg'}}
            {{#if metadata.title_1.value}}
              <button
                id="tab1-{{ assetid }}-button"
                class="qld__tab-button active"
                role="tab"
                data-tab="tab1-{{ assetid }}"
                aria-selected="true"
                aria-controls="tab1-{{ assetid }}-content"
                tabindex="0"
              >
                <span>
                  {{#if metadata.icon_1.value}}
                    <svg
                      class="qld__icon qld__icon--sm"
                      aria-hidden="true"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <use
                        href="{{ @root.site.metadata.coreSiteIcons.value }}#{{ metadata.icon_1.value }}"
                      ></use>
                    </svg>
                  {{/if}}
                  {{ metadata.title_1.value }}
                </span>
              </button>
            {{/if}}
            {{#ifCond metadata.tab_num.value '>=' '2'}}
              {{#if metadata.title_2.value}}
                <button
                  id="tab2-{{ assetid }}-button"
                  class="qld__tab-button"
                  role="tab"
                  data-tab="tab2-{{ assetid }}"
                  aria-selected="false"
                  aria-controls="tab2-{{ assetid }}-content"
                  tabindex="-1"
                >
                  <span>
                    {{#if metadata.icon_2.value}}
                      <svg
                        class="qld__icon qld__icon--sm"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <use
                          href="{{ @root.site.metadata.coreSiteIcons.value }}#{{ metadata.icon_2.value }}"
                        ></use>
                      </svg>
                    {{/if}}
                    {{ metadata.title_2.value }}
                  </span>
                </button>
              {{/if}}
            {{/ifCond}}
            {{#ifCond metadata.tab_num.value '>=' '3'}}
              {{#if metadata.title_3.value}}
                <button
                  id="tab3-{{ assetid }}-button"
                  class="qld__tab-button"
                  role="tab"
                  data-tab="tab3-{{ assetid }}"
                  aria-selected="false"
                  aria-controls="tab3-{{ assetid }}-content"
                  tabindex="-1"
                >
                  <span>
                    {{#if metadata.icon_3.value}}
                      <svg
                        class="qld__icon qld__icon--sm"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <use
                          href="{{ @root.site.metadata.coreSiteIcons.value }}#{{ metadata.icon_3.value }}"
                        ></use>
                      </svg>
                    {{/if}}
                    {{ metadata.title_3.value }}
                  </span>
                </button>
              {{/if}}
            {{/ifCond}}
            {{#ifCond metadata.tab_num.value '>=' '4'}}
              {{#if metadata.title_4.value}}
                <button
                  id="tab4-{{ assetid }}-button"
                  class="qld__tab-button"
                  role="tab"
                  data-tab="tab4-{{ assetid }}"
                  aria-selected="false"
                  aria-controls="tab4-{{ assetid }}-content"
                  tabindex="-1"
                >
                  <span>
                    {{#if metadata.icon_4.value}}
                      <svg
                        class="qld__icon qld__icon--sm"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <use
                          href="{{ @root.site.metadata.coreSiteIcons.value }}#{{ metadata.icon_4.value }}"
                        ></use>
                      </svg>
                    {{/if}}
                    {{ metadata.title_4.value }}
                  </span>
                </button>
              {{/if}}
            {{/ifCond}}
            {{#ifCond metadata.tab_num.value '>=' '5'}}
              {{#if metadata.title_5.value}}
                <button
                  id="tab5-{{ assetid }}-button"
                  class="qld__tab-button"
                  role="tab"
                  data-tab="tab5-{{ assetid }}"
                  aria-selected="false"
                  aria-controls="tab5-{{ assetid }}-content"
                  tabindex="-1"
                >
                  <span>
                    {{#if metadata.icon_5.value}}
                      <svg
                        class="qld__icon qld__icon--sm"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <use
                          href="{{ @root.site.metadata.coreSiteIcons.value }}#{{ metadata.icon_5.value }}"
                        ></use>
                      </svg>
                    {{/if}}
                    {{ metadata.title_5.value }}
                  </span>
                </button>
              {{/if}}
            {{/ifCond}}
            {{#ifCond metadata.tab_num.value '>=' '6'}}
              {{#if metadata.title_6.value}}
                <button
                  id="tab6-{{ assetid }}-button"
                  class="qld__tab-button"
                  role="tab"
                  data-tab="tab6-{{ assetid }}"
                  aria-selected="false"
                  aria-controls="tab6-{{ assetid }}-content"
                  tabindex="-1"
                >
                  <span>
                    {{#if metadata.icon_6.value}}
                      <svg
                        class="qld__icon qld__icon--sm"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <use
                          href="{{ @root.site.metadata.coreSiteIcons.value }}#{{ metadata.icon_6.value }}"
                        ></use>
                      </svg>
                    {{/if}}
                    {{ metadata.title_6.value }}
                  </span>
                </button>
              {{/if}}
            {{/ifCond}}
            {{#ifCond metadata.tab_num.value '>=' '7'}}
              {{#if metadata.title_7.value}}
                <button
                  id="tab7-{{ assetid }}-button"
                  class="qld__tab-button"
                  role="tab"
                  data-tab="tab7-{{ assetid }}"
                  aria-selected="false"
                  aria-controls="tab7-{{ assetid }}-content"
                  tabindex="-1"
                >
                  <span>
                    {{#if metadata.icon_7.value}}
                      <svg
                        class="qld__icon qld__icon--sm"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <use
                          href="{{ @root.site.metadata.coreSiteIcons.value }}#{{ metadata.icon_7.value }}"
                        ></use>
                      </svg>
                    {{/if}}
                    {{ metadata.title_7.value }}
                  </span>
                </button>
              {{/if}}
            {{/ifCond}}
            {{#ifCond metadata.tab_num.value '>=' '8'}}
              {{#if metadata.title_8.value}}
                <button
                  id="tab8-{{ assetid }}-button"
                  class="qld__tab-button"
                  role="tab"
                  data-tab="tab8-{{ assetid }}"
                  aria-selected="false"
                  aria-controls="tab8-{{ assetid }}-content"
                  tabindex="-1"
                >
                  <span>
                    {{#if metadata.icon_8.value}}
                      <svg
                        class="qld__icon qld__icon--sm"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <use
                          href="{{ @root.site.metadata.coreSiteIcons.value }}#{{ metadata.icon_8.value }}"
                        ></use>
                      </svg>
                    {{/if}}
                    {{ metadata.title_8.value }}
                  </span>
                </button>
              {{/if}}
            {{/ifCond}}
            {{#ifCond metadata.tab_num.value '>=' '9'}}
              {{#if metadata.title_9.value}}
                <button
                  id="tab9-{{ assetid }}-button"
                  class="qld__tab-button"
                  role="tab"
                  data-tab="tab9-{{ assetid }}"
                  aria-selected="false"
                  aria-controls="tab9-{{ assetid }}-content"
                  tabindex="-1"
                >
                  <span>
                    {{#if metadata.icon_9.value}}
                      <svg
                        class="qld__icon qld__icon--sm"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <use
                          href="{{ @root.site.metadata.coreSiteIcons.value }}#{{ metadata.icon_9.value }}"
                        ></use>
                      </svg>
                    {{/if}}
                    {{ metadata.title_9.value }}
                  </span>
                </button>
              {{/if}}
            {{/ifCond}}
            {{#ifCond metadata.tab_num.value '>=' '10'}}
              {{#if metadata.title_10.value}}
                <button
                  id="tab10-{{ assetid }}-button"
                  class="qld__tab-button"
                  role="tab"
                  data-tab="tab10-{{ assetid }}"
                  aria-selected="false"
                  aria-controls="tab10-{{ assetid }}-content"
                  tabindex="-1"
                >
                  <span>
                    {{#if metadata.icon_10.value}}
                      <svg
                        class="qld__icon qld__icon--sm"
                        aria-hidden="true"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <use
                          href="{{ @root.site.metadata.coreSiteIcons.value }}#{{ metadata.icon_10.value }}"
                        ></use>
                      </svg>
                    {{/if}}
                    {{ metadata.title_10.value }}
                  </span>
                </button>
              {{/if}}
            {{/ifCond}}
          {{else}}
            {{#each ../component.assets}}
              <button
                id="tab{{ @key }}-button"
                class="
                  qld__tab-button
                  {{#ifCond @key '==' 0}}
                    active
                  {{/ifCond}}
                "
                role="tab"
                data-tab="tab{{ @key }}-{{ this.assetid }}"
                aria-selected="{{#ifCond @key '==' 0}}true{{else}}false{{/ifCond}}"
                aria-controls="tab{{ @key }}-{{ this.assetid }}-content"
                tabindex="{{#ifCond @key '==' 0}}0{{else}}-1{{/ifCond}}"
              >
                <span>
                  {{#if this.metadata.tabIcon.value}}
                    <svg
                      class="qld__icon qld__icon--sm"
                      aria-hidden="true"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <use
                        href="{{ @root.site.metadata.coreSiteIcons.value }}#{{ this.metadata.tabIcon.value }}"
                      ></use>
                    </svg>
                  {{/if}}
                  {{ this.name }}
                </span>
              </button>
            {{/each}}
          {{/ifCond}}
        </div>
        {{#ifCond metadata.type.value '==' 'wysiwyg'}}
          {{#if metadata.content_1.value}}
            <div
              id="tab1-{{ assetid }}-content"
              class="qld__tab-content active"
              data-tab="tab1-{{ assetid }}"
              role="tabpanel"
              aria-labelledby="tab1-{{ assetid }}-button"
              tabindex="0"
              aria-hidden="false"
            >
              {{{ metadata.content_1.value }}}
            </div>
          {{/if}}
          {{#ifCond metadata.tab_num.value '>=' '2'}}
            {{#if metadata.content_2.value}}
              <div
                id="tab2-{{ assetid }}-content"
                class="qld__tab-content"
                data-tab="tab2-{{ assetid }}"
                role="tabpanel"
                aria-labelledby="tab2-{{ assetid }}-button"
                tabindex="0"
              >
                {{{ metadata.content_2.value }}}
              </div>
            {{/if}}
          {{/ifCond}}
          {{#ifCond metadata.tab_num.value '>=' '3'}}
            {{#if metadata.content_3.value}}
              <div
                id="tab3-{{ assetid }}-content"
                class="qld__tab-content"
                data-tab="tab3-{{ assetid }}"
                role="tabpanel"
                aria-labelledby="tab3-{{ assetid }}-button"
                tabindex="0"
              >
                {{{ metadata.content_3.value }}}
              </div>
            {{/if}}
          {{/ifCond}}
          {{#ifCond metadata.tab_num.value '>=' '4'}}
            {{#if metadata.content_4.value}}
              <div
                id="tab4-{{ assetid }}-content"
                class="qld__tab-content"
                data-tab="tab4-{{ assetid }}"
                role="tabpanel"
                aria-labelledby="tab4-{{ assetid }}-button"
                tabindex="0"
              >
                {{{ metadata.content_4.value }}}
              </div>
            {{/if}}
          {{/ifCond}}
          {{#ifCond metadata.tab_num.value '>=' '5'}}
            {{#if metadata.content_5.value}}
              <div
                id="tab5-{{ assetid }}-content"
                class="qld__tab-content"
                data-tab="tab5-{{ assetid }}"
                role="tabpanel"
                aria-labelledby="tab5-{{ assetid }}-button"
                tabindex="0"
              >
                {{{ metadata.content_5.value }}}
              </div>
            {{/if}}
          {{/ifCond}}
          {{#ifCond metadata.tab_num.value '>=' '6'}}
            {{#if metadata.content_6.value}}
              <div
                id="tab6-{{ assetid }}-content"
                class="qld__tab-content"
                data-tab="tab6-{{ assetid }}"
                role="tabpanel"
                aria-labelledby="tab6-{{ assetid }}-button"
                tabindex="0"
              >
                {{{ metadata.content_6.value }}}
              </div>
            {{/if}}
          {{/ifCond}}
          {{#ifCond metadata.tab_num.value '>=' '7'}}
            {{#if metadata.content_7.value}}
              <div
                id="tab7-{{ assetid }}-content"
                class="qld__tab-content"
                data-tab="tab7-{{ assetid }}"
                role="tabpanel"
                aria-labelledby="tab7-{{ assetid }}-button"
                tabindex="0"
              >
                {{{ metadata.content_7.value }}}
              </div>
            {{/if}}
          {{/ifCond}}
          {{#ifCond metadata.tab_num.value '>=' '8'}}
            {{#if metadata.content_8.value}}
              <div
                id="tab8-{{ assetid }}-content"
                class="qld__tab-content"
                data-tab="tab8-{{ assetid }}"
                role="tabpanel"
                aria-labelledby="tab8-{{ assetid }}-button"
                tabindex="0"
              >
                {{{ metadata.content_8.value }}}
              </div>
            {{/if}}
          {{/ifCond}}
          {{#ifCond metadata.tab_num.value '>=' '9'}}
            {{#if metadata.content_9.value}}
              <div
                id="tab9-{{ assetid }}-content"
                class="qld__tab-content"
                data-tab="tab9-{{ assetid }}"
                role="tabpanel"
                aria-labelledby="tab9-{{ assetid }}-button"
                tabindex="0"
              >
                {{{ metadata.content_9.value }}}
              </div>
            {{/if}}
          {{/ifCond}}
          {{#ifCond metadata.tab_num.value '>=' '9'}}
            {{#if metadata.content_10.value}}
              <div
                id="tab10-{{ assetid }}-content"
                class="qld__tab-content"
                data-tab="tab10-{{ assetid }}"
                role="tabpanel"
                aria-labelledby="tab10-{{ assetid }}-button"
                tabindex="0"
              >
                {{{ metadata.content_10.value }}}
              </div>
            {{/if}}
          {{/ifCond}}
        {{else}}
          {{#each ../component.assets}}
            <div
              id="tab{{ @key }}-{{ this.assetid }}-content"
              class="
                qld__tab-content
                {{#ifCond @key '==' 0}}
                  active
                {{/ifCond}}
              "
              data-tab="tab{{ @key }}-{{ this.assetid }}"
              role="tabpanel"
              aria-labelledby="tab{{ @key }}-{{ this.assetid }}-button"
              tabindex="0"
              {{#ifCond @key '==' 0}}
                aria-hidden="false"
              {{/ifCond}}
            >
              {{{ this.rawcontent }}}
            </div>
          {{/each}}
        {{/ifCond}}
      </div>
    </div>
  </section>
{{/with}}
