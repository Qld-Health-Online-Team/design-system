{{#with component.data}}
  <section
    id="{{#if metadata.id_field.value}}{{ metadata.id_field.value }}{{else}}horizontal-rule-{{ assetid }}{{/if}}"
    class="qld__body"
  >
    <hr
      class="
        qld__horizontal-rule
        {{
        metadata.colour.value
        }}
        {{
        metadata.theme.value
        }}
      "
      style="
        height:{{ metadata.height.value }};margin-top:{{ metadata.margin_top.value }};margin-bottom:{{ metadata.margin_top.value }};
      "
      aria-hidden="true"
    />
  </section>
{{/with}}
